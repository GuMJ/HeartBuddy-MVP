# HeartBuddy 环境变量配置
# 复制此文件为 .env 并填入真实值

# DeepSeek API（必填）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 数据库路径（相对于项目根目录）
DB_PATH=data/heartbuddy.db

# 日志路径
LOG_PATH=logs/heartbuddy.log

# 上下文
MAX_CONTEXT_MESSAGES=20

# 模型参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
